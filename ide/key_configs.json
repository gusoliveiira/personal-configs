[
    // Disabling Toggle Sidebar unbound
    {
        "key": "ctrl+b",
        "command": "-workbench.action.toggleSidebarVisibility"
    },
    // Go to Definition
    {
        "key": "ctrl+b",
        "command": "editor.action.goToDeclaration",
        "when": "editorHasDefinitionProvider && editorTextFocus"
    },
    // Go to Implementation
    {
        "key": "ctrl+b",
        "command": "editor.action.goToImplementation",
        "when": "editorHasImplementationProvider && editorTextFocus"
    },
    // Go Back: Ctrl + Super + Left
    {
        "key": "ctrl+alt+left", //Windows has ctrl+windows+left to switch to a different desktop worskpace, so switching to alt. For linux, unnecessary;
        "command": "workbench.action.navigateBack",
        "when": "editorTextFocus"
    },
    // Go Forward: Ctrl + Super + Right
    {
        "key": "ctrl+alt+right",
        "command": "workbench.action.navigateForward",
        "when": "editorTextFocus"
    },
    // Navigation between methods (folds)
    {
        "key": "ctrl+shift+down",
        "command": "editor.gotoNextFold",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+shift+up",
        "command": "editor.gotoPreviousFold",
        "when": "editorTextFocus"
    }
]
